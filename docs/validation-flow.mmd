flowchart TD
    A(["User writes validation rule
e.g. 'CPF valido'"]) --> B

    B{"Tool exists
in library?"}

    B -->|YES| C["Load cached code
from Lakebase"]
    B -->|NO| D["LLM generates
Python code"]

    C --> E[Execute locally]
    D --> F["Save as new tool
in Lakebase"]
    F --> G[Execute locally]

    E --> H(["Return result
instant"])
    G --> I([Return result])

    I --> J(["Subsequent calls
always take cached path"])
    J --> B

